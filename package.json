{
  "name": "baby-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Edd Mann <the@eddmann.com>",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply baby-tracker-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply baby-tracker-db --remote",
    "ship": "bun run typecheck && bun run build && bun run db:migrate:remote && bun run deploy",
    "test": "bun test worker/test/",
    "test:repositories": "bun test worker/test/repositories/",
    "test:http": "bun test worker/test/http/",
    "test:usecases": "bun test worker/test/usecases/"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@reduxjs/toolkit": "^2.11.2",
    "hono": "^4.11.7",
    "lucide-react": "^0.468.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.23.0",
    "@cloudflare/workers-types": "^4.20260203.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "bun-types": "^1.3.8",
    "wrangler": "^4.62.0"
  }
}
